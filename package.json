{
  "name": "ciphersheet",
  "private": true,
  "version": "0.1.0",
  "description": "CipherSheet build and deploy tooling",
  "scripts": {
    "build:apps-script": "node scripts/build-apps-script.mjs",
    "clasp:push": "npm run build:apps-script && clasp push --force",
    "clasp:version": "npm run build:apps-script && clasp version",
    "clasp:deploy": "npm run build:apps-script && clasp push --force && clasp deploy",
    "pages:preview": "node scripts/preview-pages-paths.mjs"
  },
  "devDependencies": {
    "@google/clasp": "^2.5.0",
    "@types/google-apps-script": "^1.0.98",
    "typescript": "^5.8.2"
  },
  "engines": {
    "node": ">=22"
  }
}
